{
    "name": "prodstarter/filament-notification-center",
    "description": "Extend Filament's notification drawer with customizable tabs and notification categories for a cleaner, more organized user experience",
    "keywords": [
        "prodstarter",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-notification-center"
    ],
    "homepage": "https://github.com/prodstarter/filament-notification-center",
    "support": {
        "issues": "https://github.com/prodstarter/filament-notification-center/issues",
        "source": "https://github.com/prodstarter/filament-notification-center"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Stanley Ojadovwa",
            "email": "stanley.warri@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Prodstarter\\FilamentNotificationCenter\\": "src/",
            "Prodstarter\\FilamentNotificationCenter\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Prodstarter\\FilamentNotificationCenter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test": "pest",
        "test:lint": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Prodstarter\\FilamentNotificationCenter\\FilamentNotificationCenterServiceProvider"
            ],
            "aliases": {
                "FilamentNotificationCenter": "Prodstarter\\FilamentNotificationCenter\\Facades\\FilamentNotificationCenter"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}